{
  "name": "@zetesis/quartz-okf-panels",
  "version": "0.1.0",
  "description": "OKF viewer panels for Quartz: a per-note blast-radius view derived from the typed topology graph",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "quartz",
    "quartz-plugin",
    "okf",
    "component"
  ],
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "@quartz-community/types": "github:quartz-community/types"
  },
  "peerDependencies": {
    "preact": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "esbuild": "^0.24.0",
    "preact": "^10.28.2",
    "sass": "^1.97.3",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10.9.2"
  },
  "quartz": {
    "name": "quartz-okf-panels",
    "displayName": "OKF Panels",
    "category": "component",
    "version": "0.1.0",
    "quartzVersion": ">=5.0.0",
    "components": {
      "BlastRadius": {
        "displayName": "Blast Radius",
        "defaultPosition": "right",
        "defaultPriority": 15
      }
    }
  }
}
