import assert from "node:assert/strict"
import fs from "node:fs/promises"
import os from "node:os"
import path from "node:path"
import test from "node:test"
import { OkfEmitter, OkfTransformer } from "../quartz-okf/dist/index.js"

test("Quartz wrapper delegates validation and graph construction to the shared core", async () => {
  const file = {
    path: "content/service.md",
    value: "# Topology\n\n* **Uses**: [[pending]]\n",
    data: {
      filePath: "content/service.md",
      slug: "service",
      frontmatter: {
        type: "service",
        title: "Service",
        description: "A service.",
        tags: ["fleet"],
      },
    },
  }
  const transformer = OkfTransformer()
  const plugin = transformer.markdownPlugins()[0]()
  plugin(null, file)
  assert.equal(file.data.okf.edges.length, 1)
  assert.deepEqual(file.data.frontmatter.tags, ["fleet", "type/service"])

  const output = await fs.mkdtemp(path.join(os.tmpdir(), "okf-quartz-test-"))
  const emitter = OkfEmitter()
  const emitted = await emitter.emit(
    {
      argv: { output },
      cfg: { configuration: { pageTitle: "Test" } },
    },
    [[null, file]],
  )
  assert.equal(emitted.some((item) => item.endsWith("okf-graph.json")), true)
  const graph = JSON.parse(await fs.readFile(path.join(output, "static/okf-graph.json")))
  assert.equal(graph.stats.notes, 1)
  assert.equal(graph.stats.unresolvedEdges, 1)
  assert.match(await fs.readFile(path.join(output, "raw/service.md"), "utf8"), /type: service/)
})
